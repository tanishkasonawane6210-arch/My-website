/* Reset & Body */
body{
    margin:0;
    font-family: 'Arial', sans-serif;
    background-color: #f4f4f4;
    color: #333;
}

/* Header */
header{
    background: #1e3d59;
    color: white;
    text-align: center;
    padding: 30px 20px;
}

header h1{
    margin: 0;
    font-size: 2.5em;
}

header p{
    margin: 5px 0 0 0;
    font-size: 1.2em;
}

/* Navigation */
nav{
    background: #34495e;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
}

nav a{
    color: white;
    text-decoration: none;
    padding: 14px 20px;
    display: block;
    transition: 0.3s;
}

nav a:hover{
    background: #1abc9c;
    color: white;
}

/* Container */
.container{
    display: flex;
    flex-wrap: wrap;
    padding: 20px;
    gap: 20px;
}

/* Sidebar */
.sidebar{
    flex: 1;
    min-width: 220px;
    background: #ecf0f1;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    text-align: center;
}

/* Profile Picture */
.profile-pic{
    width: 150px;
    height: 150px;
    border-radius: 50%;
    margin-bottom: 15px;
    object-fit: cover;
    border: 3px solid #1e3d59;
}

/* Sidebar list */
.sidebar ul{
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
}

.sidebar ul li{
    margin: 10px 0;
    font-size: 1em;
}

.sidebar ul li a{
    color: #1e3d59;
    text-decoration: none;
}

.sidebar ul li a:hover{
    color: #1abc9c;
}

/* Content */
.content{
    flex: 3;
    min-width: 300px;
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.content h2{
    color: #1e3d59;
    margin-top: 0;
    border-bottom: 2px solid #1abc9c;
    padding-bottom: 5px;
}

/* Skills progress bars */
.skill{
    margin: 10px 0 15px 0;
}

.skill p{
    margin: 0 0 5px 0;
    font-weight: bold;
}

.skill-bar{
    height: 15px;
    background-color: #1abc9c;
    border-radius: 10px;
}

/* Projects list styling */
.content ul li{
    margin: 8px 0;
    line-height: 1.5;
}

/* Contact Form */
form input, form textarea{
    width: 100%;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 5px;
    border: 1px solid #ccc;
    font-size: 1em;
}

form button{
    padding: 10px 20px;
    background-color: #1e3d59;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-size: 1em;
}

form button:hover{
    background-color: #1abc9c;
}

/* Footer */
footer{
    background: #1e3d59;
    color: white;
    text-align: center;
    padding: 15px;
    margin-top: 20px;
    border-top: 3px solid #1abc9c;
}

/* Responsive Design */
@media(max-width:768px){
    .container{
        flex-direction: column;
    }
    nav{
        flex-direction: column;
        text-align: center;
    }
}